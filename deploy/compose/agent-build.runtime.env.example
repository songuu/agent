# 运行时私有配置样板。复制为 agent-build.runtime.env 后仅上传到部署机，禁止提交真实密钥。
# 站点仅会接收 NEXT_PUBLIC_* 字段；数据库密码、service role 只给 content-api / worker。

# 默认保持现有 Supabase 读写路径；Content API service 会健康启动但返回 503，浏览器继续 anon 回退。
CONTENT_API_ENABLED=0
CONTENT_REPOSITORY_DRIVER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-key
SUPABASE_SCHEMA=public
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-browser-anon-key

# 切到自建 MySQL 前：启用同源 Content API，保留 NEXT_PUBLIC_SUPABASE_* 仅作为灰度回退；
# 验证完成后可删除两项 NEXT_PUBLIC_SUPABASE_*，浏览器将不再获得任何 Supabase URL/key。
# 同一套 MySQL 私有配置由 Content API、news-collector、Notion 关系数据端口共用。
# CONTENT_API_ENABLED=1
# NEXT_PUBLIC_CONTENT_API_BASE_URL=/agent-build/api/content/v1
# CONTENT_REPOSITORY_DRIVER=mysql
# CONTENT_MYSQL_URL=mysql://content_app:replace-password@mysql.internal:3306/agent_build
# CONTENT_MYSQL_SSL=true

# 或使用分项字段（不得与 CONTENT_MYSQL_URL 同时使用）：
# CONTENT_MYSQL_HOST=mysql.internal
# CONTENT_MYSQL_PORT=3306
# CONTENT_MYSQL_DATABASE=agent_build
# CONTENT_MYSQL_USER=content_app
# CONTENT_MYSQL_PASSWORD=replace-password
# CONTENT_MYSQL_SSL=true

# 附件不在 MySQL 内：当前 Notion 图片仍使用 Supabase Storage。完全移除 Supabase 前，
# 先迁移 notion-assets 并部署 AssetStore（S3/MinIO/OSS/COS）适配器；CONTENT_ASSET_PUBLIC_BASE_URL 尚未被运行时代码消费。