# Non-secret local defaults for `docker compose config`.
# Production deploys generate the remote file from scripts/deploy-container.ps1.
# Do not put real secrets in this tracked file.
NODE_ENV=production
DEMO_RUNNER_PORT=5174
DEMO_RUNNER_ALLOWED_HOSTS=songuu.top
DEMO_RUNNER_ALLOWED_ORIGINS=https://songuu.top
DEMO_RUNNER_ALLOW_MISSING_ORIGIN=1
DEMO_RUNNER_REQUIRE_TOKEN=0
