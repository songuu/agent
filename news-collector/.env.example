# 资讯收集器环境变量模板。
# 复制相关项到【仓库根】的 .env（脚本用 --env-file=.env 加载）。
# 切勿提交真实值——活密钥只进 .env，且 .env 必须在 .gitignore 内。

# —— 写入侧 · 收集器（写库必填；缺失则自动退回 dryRun 不写库）——
# service_role 仅在 Node 收集端使用，绝不进前端 bundle。
SUPABASE_URL=https://your-supabase-host
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=public

# —— 读取侧 · 网站页面（site:build / site:dev 时由 .vitepress/config.mts 注入）——
# /news 与第 20 章用公开 anon 配置只读 news_items。缺这两项页面会报"缺少 anon"。
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-host
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# —— 可选 LLM 富化（需 key 且 NEWS_ENRICH_MAX>0 才启用）——
ANTHROPIC_API_KEY=
NEWS_ENRICH_MAX=0
NEWS_ENRICH_MODEL=claude-haiku-4-5-20251001

# —— 调度（node-cron 表达式 + 时区）——
NEWS_CRON=0 8 * * *
NEWS_TZ=Asia/Shanghai
NEWS_RUN_AT_BOOT=true

# —— 运行控制 ——
NEWS_DRY_RUN=false
NEWS_FEED_TIMEOUT_MS=15000
