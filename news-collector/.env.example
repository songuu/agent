# 资讯收集器环境变量模板。
# 复制相关项到【仓库根】的 .env（脚本用 --env-file=.env 加载）。
# 切勿提交真实值——活密钥只进 .env，且 .env 必须在 .gitignore 内。

# —— 写入侧 · 收集器（默认 Supabase；也可使用 MySQL）——
# service_role 仅在 Node 收集端使用，绝不进前端 bundle。
SUPABASE_URL=https://your-supabase-host
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=public

# 切 MySQL：设置 mysql 后新闻与 Notion 关系数据改用同一仓库端口；URL/分项字段二选一。
# CONTENT_REPOSITORY_DRIVER=mysql
# CONTENT_MYSQL_URL=mysql://content_app:replace-password@mysql.internal:3306/agent_build
# CONTENT_MYSQL_SSL=true

# —— 读取侧 · 网站页面（site:build / site:dev 时由 .vitepress/config.mts 注入）——
# 推荐使用同源 Content API；灰度期可保留完整 Supabase anon pair 回退。
NEXT_PUBLIC_CONTENT_API_BASE_URL=/agent-build/api/content/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-host
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# —— 可选 LLM 富化（需所选 provider 的 key 且 NEWS_ENRICH_MAX>0 才启用）——
# 与仓库根 .env.example 保持同一套配置：anthropic | openai | ollama。
# OpenAI-compatible 平台（如 SiliconFlow）使用 openai，并配置 OPENAI_BASE_URL。
LLM_PROVIDER=anthropic

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# 可选：collector 专用模型覆盖；通常优先用 ANTHROPIC_MODEL / OPENAI_MODEL。
# NEWS_ENRICH_MODEL=
NEWS_ENRICH_MAX=0

# —— 调度（node-cron 表达式 + 时区）——
NEWS_CRON=0 8 * * *
NEWS_TZ=Asia/Shanghai
NEWS_RUN_AT_BOOT=true

# —— 运行控制 ——
NEWS_DRY_RUN=false
NEWS_FEED_TIMEOUT_MS=15000

# —— Notion 文章同步（notion:sync / notion:cron；缺 NOTION_TOKEN 自动 dryRun 不拉取/不写库）——
# integration secret，只进 .env，绝不提交。目标数据库需共享给该 integration。
NOTION_TOKEN=
# 同步的 cursor、manifest 和 notion_articles 通过上方 ContentRepository 写入（可为 MySQL）。
# 图片当前仍重托管到 Supabase Storage public bucket，因此完全脱离 Supabase 前需接入独立 AssetStore。
NOTION_STORAGE_BUCKET=notion-assets
# 调度：默认每日 08:30，与 NEWS_CRON(08:00) 错峰。
NOTION_CRON=30 8 * * *
NOTION_TZ=Asia/Shanghai
NOTION_RUN_AT_BOOT=true
NOTION_DRY_RUN=false
# 每次同步最多处理多少页（0=不限，防首次全量打爆限流；设上限时最旧优先、最新延后若干轮可见）。
NOTION_MAX_PAGES_PER_SYNC=0
# 忽略增量水位、全量重拉（backfill / 图片整体重托管时临时开）。
NOTION_FULL_RESYNC=false

# —— 原文正文抽取（用于 /news/article 站内详情页）——
NEWS_ARTICLE_CONTENT_ENABLED=true
NEWS_ARTICLE_CONTENT_TIMEOUT_MS=12000
NEWS_ARTICLE_CONTENT_MAX_ITEMS=80
