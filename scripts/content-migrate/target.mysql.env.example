# 只用于 Supabase -> MySQL 内容表迁移的目标端凭据。复制到仓库根 .env.content-mysql，禁止提交真实值。
CONTENT_REPOSITORY_DRIVER=mysql
# 二选一：推荐单一 URL，供 Content API、news collector、Notion DB 端口与迁移器共用。
CONTENT_MYSQL_URL=mysql://content_migrator:replace-password@mysql.internal:3306/agent_build
CONTENT_MYSQL_SSL=true

# 或改用分项字段（不得与 CONTENT_MYSQL_URL 同时使用）：
# CONTENT_MYSQL_HOST=mysql.internal
# CONTENT_MYSQL_PORT=3306
# CONTENT_MYSQL_DATABASE=agent_build
# CONTENT_MYSQL_USER=content_migrator
# CONTENT_MYSQL_PASSWORD=replace-password
# CONTENT_MYSQL_SSL=true