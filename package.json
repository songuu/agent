{
  "name": "agent-from-scratch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "从零手写到上框架：一套面向初学者的 TypeScript Agent 开发完整学习路径",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lesson": "tsx",
    "capstone": "tsx capstone/deep-research-agent/src/cli.ts",
    "rag:capstone": "tsx capstone/rag-system/src/checkpoint.ts",
    "support-copilot": "tsx capstone/support-copilot/src/cli.ts",
    "support-copilot:smoke": "tsx capstone/support-copilot/src/smoke.ts",
    "code-review-crew": "tsx capstone/code-review-crew/src/cli.ts",
    "code-review-crew:smoke": "tsx capstone/code-review-crew/src/smoke.ts",
    "agent-eval-harness": "tsx capstone/agent-eval-harness/src/cli.ts",
    "agent-eval-harness:smoke": "tsx capstone/agent-eval-harness/src/smoke.ts",
    "capstone:smoke": "pnpm support-copilot:smoke && pnpm code-review-crew:smoke && pnpm agent-eval-harness:smoke && pnpm incident-responder:smoke && pnpm feedback-intelligence:smoke && pnpm sales-lead-researcher:smoke && pnpm capstone:catalog:smoke",
    "kg": "tsx knowledge-graph/generate.ts",
    "supabase:runtime-config": "tsx scripts/write-supabase-runtime-config.ts",
    "supabase:migrate": "tsx scripts/supabase-migrate/cli.ts",
    "supabase:move": "tsx scripts/supabase-move.ts",
    "supabase:cutover": "tsx scripts/supabase-cutover.ts",
    "supabase:typecheck": "tsc -p tsconfig.supabase-migrate.json --noEmit && tsc -p tsconfig.supabase-public.json --noEmit",
    "content:api:prod": "tsx scripts/content-api/start-production.ts",
    "content:api:test": "node --experimental-transform-types scripts/content-api/contract.test.mts && node --experimental-transform-types scripts/content-api/repository.test.mts && node --experimental-transform-types scripts/content-api/server.test.mts",
    "content:api:typecheck": "tsc -p tsconfig.content-api.json --noEmit",
    "content:migrate:mysql": "tsx scripts/content-migrate/mysql-cli.ts",
    "content:migrate:mysql:test": "node --experimental-transform-types scripts/content-migrate/mysql.test.mts",
    "content:migrate:mysql:typecheck": "tsc -p tsconfig.content-migrate.json --noEmit",
    "supabase:frontier-seed": "tsx scripts/generate-frontier-ecosystem-supabase-seed.ts",
    "supabase:interview-seed": "tsx scripts/generate-interview-questions-supabase-seed.ts",
    "supabase:glossary-seed": "tsx scripts/generate-glossary-supabase-seed.ts",
    "supabase:frontier-push": "tsx --env-file=.env scripts/push-frontier-ecosystem-to-supabase.ts",
    "supabase:frontier-read": "tsx --env-file=.env scripts/read-frontier-ecosystem-from-supabase.ts",
    "supabase:glossary-push": "tsx --env-file=.env scripts/push-glossary-to-supabase.ts",
    "supabase:codefather-interview-sync": "node --experimental-transform-types --env-file=.env scripts/sync-codefather-interview-to-supabase.ts",
    "codefather:interview-cron": "node --experimental-transform-types --env-file=.env scripts/codefather-interview-cron.ts",
    "deploy:codefather-interview-sync": "pwsh scripts/deploy-codefather-interview-sync.ps1",
    "supabase:news-seed": "tsx scripts/generate-news-items-seed.ts",
    "supabase:notion-seed": "tsx scripts/generate-notion-articles-seed.ts",
    "supabase:notion-push": "tsx --env-file=.env scripts/push-notion-articles-to-supabase.ts",
    "news:smoke": "tsx news-collector/smoke.ts",
    "news:collect": "tsx --env-file=.env news-collector/src/cli-collect.ts",
    "news:cron": "tsx --env-file=.env news-collector/src/cron.ts",
    "news:test": "tsx --test news-collector/__tests__/classify.test.mts news-collector/__tests__/article-content.test.mts news-collector/__tests__/normalize.test.mts news-collector/__tests__/dedupe.test.mts news-collector/__tests__/rss.test.mts news-collector/__tests__/collect.test.mts news-collector/__tests__/config.test.mts news-collector/__tests__/enrich.test.mts news-collector/__tests__/sources.test.mts",
    "news:repository:test": "node --experimental-transform-types news-collector/__tests__/content-repository.test.mts && node --experimental-transform-types news-collector/__tests__/config.test.mts && node --experimental-transform-types news-collector/__tests__/collect.test.mts",
    "news:repository:typecheck": "tsc -p news-collector/tsconfig.content-repository.json --noEmit",
    "notion:typecheck": "tsc -p tsconfig.notion.json --noEmit",
    "notion:smoke": "tsx news-collector/src/notion/smoke.ts",
    "notion:sync": "node --dns-result-order=ipv4first node_modules/tsx/dist/cli.mjs --env-file=news-collector/.env news-collector/src/notion/cli-sync.ts",
    "notion:cron": "node --dns-result-order=ipv4first node_modules/tsx/dist/cli.mjs --env-file=news-collector/.env news-collector/src/notion/cron.ts",
    "notion:test": "tsx --test news-collector/__tests__/notion-client-version.test.mts news-collector/__tests__/notion-client.test.mts news-collector/__tests__/notion-config.test.mts news-collector/__tests__/notion-map.test.mts news-collector/__tests__/notion-query.test.mts news-collector/__tests__/notion-assets.test.mts news-collector/__tests__/notion-store.test.mts news-collector/__tests__/notion-sync.test.mts .vitepress/theme/notion-articles-filter.test.mts .vitepress/theme/notion-markdown.test.mts",
    "rag:smoke": "tsx rag-advanced/smoke.ts",
    "rag:eval": "tsx rag-advanced/05-rag-evaluation/eval-gate.ts",
    "lg:smoke": "tsx langgraph-advanced/smoke.ts",
    "rag:build-fixture": "tsx scripts/build-embedding-fixture.ts",
    "site:dev": "vitepress dev",
    "site:build": "pnpm supabase:runtime-config && vitepress build",
    "site:preview": "vitepress preview",
    "demo:server": "tsx scripts/demo-runner/start.mts",
    "demo:server:prod": "tsx scripts/demo-runner/start-production.mts",
    "demo:clear-token": "node scripts/demo-runner/clear-token.mjs",
    "demo:wait-token": "node scripts/demo-runner/wait-token.mjs",
    "site:live": "pnpm demo:clear-token && concurrently --kill-others --names runner,site \"pnpm demo:server\" \"pnpm demo:wait-token && pnpm site:dev\"",
    "incident-responder": "tsx capstone/incident-responder/src/cli.ts",
    "incident-responder:smoke": "tsx capstone/incident-responder/src/smoke.ts",
    "feedback-intelligence": "tsx capstone/feedback-intelligence/src/cli.ts",
    "feedback-intelligence:smoke": "tsx capstone/feedback-intelligence/src/smoke.ts",
    "sales-lead-researcher": "tsx capstone/sales-lead-researcher/src/cli.ts",
    "sales-lead-researcher:smoke": "tsx capstone/sales-lead-researcher/src/smoke.ts",
    "capstone:catalog:generate": "node scripts/generate-capstone-readmes.mjs",
    "capstone:catalog:smoke": "node scripts/verify-capstone-catalog.mjs"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "typescript",
    "rag",
    "langgraph",
    "tutorial",
    "course"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@anthropic-ai/sdk": "^0.40.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@notionhq/client": "^2.3.0",
    "ai": "^4.0.0",
    "dotenv": "^16.4.0",
    "mysql2": "^3.23.1",
    "node-cron": "^4.2.1",
    "notion-to-md": "^3.1.9",
    "openai": "^4.77.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^10.0.3",
    "debug": "^4.4.0",
    "dompurify": "^3.4.10",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
