# ============================================================
# 复制本文件为 .env 并填入你自己的 key：
#   Windows PowerShell:  Copy-Item .env.example .env
#   macOS / Linux:       cp .env.example .env
# .env 已被 .gitignore 忽略，绝不会提交到仓库。
# ============================================================

# 选择默认 LLM 厂商：anthropic | openai | ollama
# OpenAI-compatible 平台（如 SiliconFlow）也使用 openai，并配置 OPENAI_BASE_URL。
# 整个课程切换厂商只需改这一行，代码无需改动。
LLM_PROVIDER=anthropic

# ---- Anthropic (Claude) ----
# 申请：https://console.anthropic.com/  →  Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# 可选：覆盖默认模型
ANTHROPIC_MODEL=claude-opus-4-8

# ---- OpenAI ----
# 申请：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
# 可选：OpenAI-compatible API base URL。
# SiliconFlow: https://api.siliconflow.cn/v1
OPENAI_BASE_URL=

# ---- Ollama (OpenAI-compatible local server) ----
# 先启动本地 ollama，再把 LLM_PROVIDER 改成 ollama。
# 默认地址是 http://127.0.0.1:11434/v1，API key 可留空（代码会使用本地占位值）。
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=

# ---- Embedding（向量检索 / RAG 章节用）----
# embedding 走同一套 OpenAI-compatible endpoint。
# OpenAI 默认：text-embedding-3-small
# SiliconFlow 示例：BAAI/bge-m3
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- SiliconFlow 示例（不要和上面的默认值同时启用两套）----
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=deepseek-ai/DeepSeek-V4-Pro
# OPENAI_EMBEDDING_MODEL=BAAI/bge-m3
