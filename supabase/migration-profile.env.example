# Copy this file twice outside Git, then fill source and target credentials:
#   Copy-Item supabase/migration-profile.env.example .env.supabase-source
#   Copy-Item supabase/migration-profile.env.example .env.supabase-target
# The migration runner reads the two files separately. Do not put either file in Git.
#
# This profile covers the Agent course content data plane only:
# five public tables plus the `notion-assets` Storage bucket. It does NOT silently
# migrate Auth users, Edge Functions, Realtime configuration, Dashboard settings,
# or unmanaged database extensions.

# Service-side PostgREST endpoint and key. service role stays in this local profile only.
SUPABASE_URL=https://your-supabase.example.com
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_SCHEMA=public

# Required for the stage phase that applies supabase/migrations with psql.
# Leave empty only when the target schema was created and audited separately, then run with --skip-schema.
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.example.com:5432/postgres

# Browser-safe public configuration. Never put SUPABASE_SERVICE_ROLE_KEY under NEXT_PUBLIC_ variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Storage bucket used by Notion article image rehosting. Keep this stable unless a deliberate bucket rename is planned.
NOTION_STORAGE_BUCKET=notion-assets
